{
  "name": "cross-chain-bridge-relayer",
  "version": "1.0.0",
  "description": "Production-quality TypeScript relayer service for Ethereum-Solana bridge",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "clean": "rm -rf dist",
    "anchor:build": "anchor build && cp target/idl/bridge.json idl/bridge.json",
    "anchor:test": "anchor test",
    "anchor:initialize": "ts-node migrations/deploy.ts",
    "anchor:update-source": "ts-node migrations/update-source-binding.ts"
  },
  "dependencies": {
    "ethers": "^6.8.1",
    "@solana/web3.js": "^1.87.6",
    "@coral-xyz/anchor": "^0.29.0",
    "@solana/spl-token": "^0.3.8",
    "better-sqlite3": "^9.2.2",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/bn.js": "^5.1.5",
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.5",
    "chai": "^4.3.10",
    "mocha": "^10.2.0",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2"
  },
  "keywords": ["blockchain", "bridge", "ethereum", "solana", "relayer"],
  "author": "Harry",
  "license": "MIT"
}