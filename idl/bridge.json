{
  "version": "0.1.0",
  "name": "bridge",
  "instructions": [
    {
      "name": "mintWrapped",
      "accounts": [
        {
          "name": "relayer",
          "isMut": true,
          "isSigner": true
        },
        {
          "name": "processedMessage",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "wrappedMint",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "recipient",
          "isMut": false,
          "isSigner": false
        },
        {
          "name": "recipientTokenAccount",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "tokenProgram",
          "isMut": false,
          "isSigner": false
        },
        {
          "name": "associatedTokenProgram",
          "isMut": false,
          "isSigner": false
        },
        {
          "name": "systemProgram",
          "isMut": false,
          "isSigner": false
        }
      ],
      "args": [
        {
          "name": "payload",
          "type": {
            "defined": "BridgePayload"
          }
        }
      ]
    }
  ],
  "types": [
    {
      "name": "BridgePayload",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "nonce",
            "type": "u64"
          },
          {
            "name": "sender",
            "type": "string"
          },
          {
            "name": "recipient",
            "type": "string"
          },
          {
            "name": "token",
            "type": "string"
          },
          {
            "name": "amount",
            "type": "u64"
          },
          {
            "name": "sourceChain",
            "type": "string"
          },
          {
            "name": "targetChain",
            "type": "string"
          },
          {
            "name": "sourceTxHash",
            "type": "string"
          }
        ]
      }
    },
    {
      "name": "ProcessedMessage",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "nonce",
            "type": "u64"
          },
          {
            "name": "processed",
            "type": "bool"
          },
          {
            "name": "timestamp",
            "type": "i64"
          }
        ]
      }
    }
  ],
  "errors": [
    {
      "code": 6000,
      "name": "MessageAlreadyProcessed",
      "msg": "Message has already been processed"
    },
    {
      "code": 6001,
      "name": "InvalidTargetChain",
      "msg": "Invalid target chain"
    },
    {
      "code": 6002,
      "name": "UnauthorizedRelayer",
      "msg": "Unauthorized relayer"
    }
  ]
}